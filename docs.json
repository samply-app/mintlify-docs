  "colors": {
    "primary": "#929298",
    "light": "#ffffff",
    "dark": "#0d0d0d"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Go to Samply",
      "href": "https://samply.app"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quick-start",
              "applications"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "overview",
              "library",
              "projects",
              "file-system"
            ]
          },
          {
            "group": "Sharing & Access",
            "pages": [
              "sharing",
              "comments",
              "embedding",
              "payments"
            ]
          },
          {
            "group": "Playback",
            "pages": [
              "playback-quality",
              "playback-gapless",
              "playback-loudness-matching",
              "playback-spatial"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "dropbox",
              "stripe"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "profile",
              "preferences",
              "security"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/squarespace",
              "guides/animated-backgrounds",
              "guides/samsung"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "faq"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction",
              "api/authentication"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "api/projects",
              "api/files",
              "api/players",
              "api/comments",
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#fcfcfc",
      "dark": "#0d0d0d"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/samply.app",
      "youtube": "https://www.youtube.com/@samply-app"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Privacy",
            "href": "https://samply.app/privacy"
          },
          {
            "label": "Terms",
            "href": "https://samply.app/terms"
          },
          {
            "label": "Security",
            "href": "https://samply.app/security"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg"
  }
}
